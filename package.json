{
  "name": "@apolosan/idea-refinement",
  "version": "1.10.1",
  "description": "Pi Coding Agent extension that runs a forced iterative idea-refinement workflow via the /idea-refine command.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "idea-refinement",
    "pi-coding-agent",
    "workflow",
    "refinement"
  ],
  "homepage": "https://github.com/apolosan/idea-refinement#readme",
  "bugs": {
    "url": "https://github.com/apolosan/idea-refinement/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apolosan/idea-refinement.git"
  },
  "license": "MIT",
  "author": "apolosan",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "pi": {
    "extensions": [
      "./index.ts",
      "./artifact-guard.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.72.0 <1.0.0"
  },
  "overrides": {
    "fast-xml-builder": "^1.2.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types tests/run-tests.ts",
    "test:ci": "node --experimental-strip-types tests/run-tests.ts",
    "release:check": "npm run typecheck && npm run test:ci && npm audit --audit-level=high && npm pack --dry-run --json"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}
